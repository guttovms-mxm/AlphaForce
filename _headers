# Security headers for static hosting (Netlify / Cloudflare Pages).
# Vercel users: see vercel.json (same policy). Plain S3/CloudFront: port
# these to the CDN response-headers config.
#
# CSP strategy: the ENFORCED policy only carries zero-breakage directives
# (frame-ancestors / base-uri / object-src). The full resource allowlist is
# shipped as Content-Security-Policy-Report-Only so it cannot break the live
# Digistore24 / CartPanda checkout. Load the funnel end-to-end, confirm the
# browser console reports no CSP violations, then move the Report-Only policy
# into Content-Security-Policy (and delete the Report-Only line).

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: frame-ancestors 'none'; base-uri 'self'; object-src 'none'
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.digistore24-scripts.com https://*.digistore24.com https://assets.mycartpanda.com https://*.mycartpanda.com https://scripts.converteai.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://*.digistore24.com https://*.digistore24-scripts.com https://*.mycartpanda.com https://*.converteai.net https://*.vturb.com https://*.vturb.com.br; media-src 'self' blob: https://*.converteai.net; frame-src https://*.digistore24.com https://checkout-ds24.com https://*.checkout-ds24.com https://*.mycartpanda.com; form-action 'self' https://*.digistore24.com https://checkout-ds24.com https://*.checkout-ds24.com https://*.mycartpanda.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'
